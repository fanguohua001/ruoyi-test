            <if test="unitCost != null">#{unitCost},</if>
            <if test="referenceType != null">#{referenceType},</if>
            <if test="referenceId != null">#{referenceId},</if>
            <if test="referenceNo != null">#{referenceNo},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="remark != null">#{remark},</if>
         </trim>
    </insert>

    <update id="updateWmsInventoryLedger" parameterType="WmsInventoryLedger">
        update wms_inventory_ledger
        <trim prefix="SET" suffixOverrides=",">
            <if test="transactionNo != null and transactionNo != ''">transaction_no = #{transactionNo},</if>
            <if test="transactionType != null">transaction_type = #{transactionType},</if>
            <if test="warehouseId != null">warehouse_id = #{warehouseId},</if>
            <if test="locationId != null">location_id = #{locationId},</if>
