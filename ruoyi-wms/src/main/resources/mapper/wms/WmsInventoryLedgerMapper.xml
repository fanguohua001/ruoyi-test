    <sql id="selectWmsInventoryLedgerVo">
        select ledger_id, transaction_no, transaction_type, warehouse_id, location_id, product_id, product_code, product_name, batch_no, qty_before, qty_change, qty_after, unit_cost, reference_type, reference_id, reference_no, create_by, create_time, remark from wms_inventory_ledger
    </sql>

    <select id="selectWmsInventoryLedgerList" parameterType="WmsInventoryLedger" resultMap="WmsInventoryLedgerResult">
        <include refid="selectWmsInventoryLedgerVo"/>
        <where>
            <if test="transactionNo != null  and transactionNo != ''"> and transaction_no = #{transactionNo}</if>
            <if test="transactionType != null  and transactionType != ''"> and transaction_type = #{transactionType}</if>
            <if test="warehouseId != null "> and warehouse_id = #{warehouseId}</if>
            <if test="locationId != null "> and location_id = #{locationId}</if>
            <if test="productId != null "> and product_id = #{productId}</if>
            <if test="productCode != null  and productCode != ''"> and product_code = #{productCode}</if>
            <if test="productName != null  and productName != ''"> and product_name like concat('%', #{productName}, '%')</if>
            <if test="batchNo != null  and batchNo != ''"> and batch_no = #{batchNo}</if>
            <if test="referenceType != null  and referenceType != ''"> and reference_type = #{referenceType}</if>
            <if test="referenceId != null "> and reference_id = #{referenceId}</if>
            <if test="referenceNo != null  and referenceNo != ''"> and reference_no = #{referenceNo}</if>
            <if test="beginTime != null"> and create_time &gt;= #{beginTime}</if>
            <if test="endTime != null"> and create_time &lt;= DATE_ADD(#{endTime}, INTERVAL 1 DAY)</if>
        </where>
        ORDER BY create_time DESC
    </select>

    <select id="selectWmsInventoryLedgerById" parameterType="Long" resultMap="WmsInventoryLedgerResult">
        <include refid="selectWmsInventoryLedgerVo"/>
        where ledger_id = #{ledgerId}
    </select>

    <insert id="insertWmsInventoryLedger" parameterType="WmsInventoryLedger" useGeneratedKeys="true" keyProperty="ledgerId">
