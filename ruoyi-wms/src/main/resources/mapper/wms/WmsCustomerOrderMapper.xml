    <select id="selectCustomerOrderList" parameterType="WmsCustomerOrder" resultMap="WmsCustomerOrderResult">
        <include refid="selectCustomerOrderVo"/>
        <where>
            <if test="orderNo != null  and orderNo != ''"> and order_no like concat('%', #{orderNo}, '%')</if>
            <if test="customerCode != null  and customerCode != ''"> and customer_code like concat('%', #{customerCode}, '%')</if>
            <if test="customerName != null  and customerName != ''"> and customer_name like concat('%', #{customerName}, '%')</if>
            <if test="orderStatus != null "> and order_status = #{orderStatus}</if>
            <if test="shipStatus != null  and shipStatus != ''"> and ship_status = #{shipStatus}</if>
        </where>
    </select>

    <select id="selectCustomerOrderById" parameterType="Long" resultMap="WmsCustomerOrderResult">
