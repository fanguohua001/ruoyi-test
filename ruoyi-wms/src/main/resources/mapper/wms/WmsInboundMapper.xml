    <sql id="selectInboundOrderVo">
        select inbound_id, inbound_no, inbound_type, source_type, source_no, supplier_id, supplier_name, warehouse_id, status, is_finished, total_qty, received_qty, qualified_qty, unqualified_qty, expected_date, actual_date, create_by, create_time, update_by, update_time, remark from wms_inbound_order
    </sql>

    <!-- 入库单列表查询（不联查明细，提升性能） -->
    <select id="selectInboundOrderList" parameterType="WmsInboundOrder" resultMap="WmsInboundOrderResult">
        SELECT
            o.inbound_id, o.inbound_no, o.inbound_type, o.source_type, o.source_no,
            o.supplier_id, o.supplier_name, o.warehouse_id, o.status, o.is_finished,
            o.total_qty, o.received_qty, o.qualified_qty, o.unqualified_qty,
            o.expected_date, o.actual_date, o.create_by, o.create_time,
            o.update_by, o.update_time, o.remark
        FROM wms_inbound_order o
        <where>
            <if test="inboundNo != null  and inboundNo != ''"> and o.inbound_no = #{inboundNo}</if>
            <if test="inboundType != null  and inboundType != ''"> and o.inbound_type = #{inboundType}</if>
            <if test="supplierId != null "> and o.supplier_id = #{supplierId}</if>
            <if test="supplierName != null  and supplierName != ''"> and o.supplier_name like concat('%', #{supplierName}, '%')</if>
            <if test="warehouseId != null "> and o.warehouse_id = #{warehouseId}</if>
            <if test="status != null  and status != ''"> and o.status = #{status}</if>
            <if test="isFinished != null "> and o.is_finished = #{isFinished}</if>
            <if test="startTime != null"> and o.create_time &gt;= #{startTime}</if>
            <if test="endTime != null"> and o.create_time &lt;= DATE_ADD(#{endTime}, INTERVAL 1 DAY)</if>
        </where>
        ORDER BY o.create_time DESC
    </select>

    <select id="selectInboundOrderById" parameterType="Long" resultMap="WmsInboundOrderResult">
        <include refid="selectInboundOrderVo"/>
        where inbound_id = #{inboundId}
    </select>

    <select id="checkInboundNoUnique" parameterType="String" resultMap="WmsInboundOrderResult">
        <include refid="selectInboundOrderVo"/>
        where inbound_no = #{inboundNo}
    </select>

